# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=0

# Database (default uses local SQLite)
DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# Monitoring defaults
DEFAULT_CHECK_INTERVAL_MINUTES=10
DEFAULT_BUFFER_PERCENT=3
DEFAULT_BUFFER_ENABLED=true

# Error notification rate-limiting
ERROR_RATE_LIMIT_HOURS=6

LOG_LEVEL=INFO

# External service URLs — change if endpoints move
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
XTRACKER_BASE_URL=https://xtracker.polymarket.com
XTRACKER_SOURCE_URL=https://xtracker.polymarket.com/user/elonmusk
